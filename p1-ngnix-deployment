#!/bin/bash

echo "🚀 Starting VRK Cloud Academy Setup..."

# Must be root
if [ "$EUID" -ne 0 ]; then
  echo "❌ Run with: sudo ./ngnix.sh"
  exit 1
fi

# Detect package manager
if command -v dnf >/dev/null 2>&1; then
    PKG="dnf"
elif command -v yum >/dev/null 2>&1; then
    PKG="yum"
elif command -v apt >/dev/null 2>&1; then
    PKG="apt"
    apt update -y
else
    echo "❌ No supported package manager found"
    exit 1
fi

echo "📦 Using package manager: $PKG"

# Install nginx
if [ "$PKG" = "yum" ]; then
    yum update -y
    amazon-linux-extras install nginx1 -y 2>/dev/null
    yum install nginx -y
else
    $PKG update -y
    $PKG install nginx -y
fi

# Start nginx (works for all systems)
service nginx start 2>/dev/null || systemctl start nginx

# Enable nginx
chkconfig nginx on 2>/dev/null || systemctl enable nginx

# Ensure directory exists
mkdir -p /usr/share/nginx/html

# Deploy professional HTML (UTF-8 FIXED)
cat << 'EOF' > /usr/share/nginx/html/index.html
